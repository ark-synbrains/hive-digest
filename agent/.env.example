# Required for live generation
ANTHROPIC_API_KEY=sk-ant-...

# Required for SMTP send
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=/dev/digest <digest@newsletters.synbrains.ai>

# Recipient of every scheduled issue
NEWSLETTER_TO_EMAIL=archana.rk@synbrains.ai

# Optional
NEWSLETTER_REPLY_TO=
NEWSLETTER_SCOPE=all
NEWSLETTER_INTERVAL_HOURS=12
ANTHROPIC_MODEL=claude-sonnet-4-6
