# Required for live generation
ANTHROPIC_API_KEY=sk-ant-...

# Required for Resend send — get a key at https://resend.com/api-keys
RESEND_API_KEY=re_...

# Must use a verified Resend domain (or onboarding@resend.dev for sandbox tests
# to your Resend account email only)
RESEND_FROM_EMAIL=/dev/digest <digest@newsletters.synbrains.ai>

# Recipients of every scheduled issue (comma, semicolon, or whitespace separated)
NEWSLETTER_TO_EMAILS=archana.rk@synbrains.ai,teammate@example.com

# Optional single-address alias (used only if NEWSLETTER_TO_EMAILS is unset)
# NEWSLETTER_TO_EMAIL=archana.rk@synbrains.ai

# Optional
NEWSLETTER_REPLY_TO=
NEWSLETTER_SCOPE=all
NEWSLETTER_INTERVAL_HOURS=12
ANTHROPIC_MODEL=claude-sonnet-4-6
