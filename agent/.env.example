# Required for live generation + send
ANTHROPIC_API_KEY=sk-ant-...
RESEND_API_KEY=re_...

# Recipient of every scheduled issue (required for your deployment)
NEWSLETTER_TO_EMAIL=archana.rk@synbrains.ai

# Must use a verified Resend domain (see README DNS section)
RESEND_FROM_EMAIL=/dev/digest <digest@newsletters.synbrains.ai>

# Optional
NEWSLETTER_REPLY_TO=
NEWSLETTER_SCOPE=all
NEWSLETTER_INTERVAL_HOURS=12
ANTHROPIC_MODEL=claude-sonnet-4-6
